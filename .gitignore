# ABOUTME: Git ignore patterns for Fastly Compute Rust project
# ABOUTME: Excludes build artifacts, local config, and IDE files

# Rust build artifacts
/target/
**/target/
**/*.rs.bk
!/Cargo.lock
!/cloud-run-transcoder/Cargo.lock

# Fastly artifacts
/bin/
*.wasm
*.tar.gz

# Local development
kv-store-data.json

# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Private journal (local only)
.private-journal/

# Git worktrees
.worktrees/
worktrees/

# Secrets and config (contain API keys)
secrets.json
config.json
secret-store-data.json

# Test files
test*.mjs
test*.sh
create-bucket.sh
*.mp4
*.ppm
*.png
node_modules/
package.json
package-lock.json
.env
migration_progress.json
scripts/backfill-fmp4-all-hashes.txt
scripts/backfill-fmp4-done.txt
scripts/backfill-fmp4-failed.txt
scripts/backfill-orientation-done.txt
scripts/backfill-orientation-affected.txt
scripts/backfill-orientation-failed.txt

# Local/ephemeral
.claude/
__pycache__/
*.log
